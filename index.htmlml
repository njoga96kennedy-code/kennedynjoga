<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MovieClub - Stream Your Favorites</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-950 text-white font-sans selection:bg-red-600 selection:text-white">

  <!-- Navigation Bar -->
  <nav class="sticky top-0 z-50 bg-gray-950/90 backdrop-blur-md border-b border-gray-800 px-6 py-4 flex items-center justify-between">
    <div class="flex items-center space-x-8">
      <h1 class="text-2xl font-black tracking-wider text-red-600 uppercase">MovieClub</h1>
      <div class="hidden md:flex space-x-6 text-sm font-medium text-gray-300">
        <a href="#" class="hover:text-white transition">Home</a>
        <a href="#" class="hover:text-white transition">Movies</a>
        <a href="#" class="hover:text-white transition">TV Shows</a>
        <a href="#" class="hover:text-white transition">My Watchlist</a>
      </div>
    </div>
    <div class="flex items-center space-x-4">
      <input type="text" placeholder="Search movies..." class="bg-gray-900 border border-gray-700 text-sm px-4 py-2 rounded-full focus:outline-none focus:border-red-600 text-gray-200 w-48 sm:w-64 transition-all">
      <button class="bg-red-600 hover:bg-red-700 px-5 py-2 text-sm font-semibold rounded-full transition shadow-lg shadow-red-600/20">Sign In</button>
    </div>
  </nav>

  <!-- Hero Section (Featured Movie) -->
  <header class="relative h-[70vh] flex items-end p-8 md:p-16 overflow-hidden bg-cover bg-center" style="background-image: linear-gradient(to top, #030712 10%, transparent 60%), url('https://images.unsplash.com/photo-1536440136628-849c177e76a1?q=80&w=1925');">
    <div class="relative z-10 max-w-2xl space-y-4">
      <span class="bg-red-600/20 text-red-500 border border-red-600/30 text-xs font-bold uppercase px-3 py-1 rounded-md tracking-wider">Trending Now</span>
      <h2 class="text-4xl md:text-6xl font-extrabold tracking-tight">Cinematic Journeys</h2>
      <p class="text-gray-300 text-sm md:text-base leading-relaxed">Explore breathtaking visuals and unmissable stories crafted by visionary directors. Stream thousands of handpicked cult classics and modern masterpieces today.</p>
      <div class="pt-2 flex space-x-4">
        <button class="bg-white text-black hover:bg-gray-200 px-6 py-3 font-bold rounded-lg transition flex items-center space-x-2">
          <span>Play Trailer</span>
        </button>
        <button class="bg-gray-800/80 hover:bg-gray-700/80 backdrop-blur-sm text-white px-6 py-3 font-bold rounded-lg transition border border-gray-700">
          + Watchlist
        </button>
      </div>
    </div>
  </header>

  <!-- Main Content / Movie Grids -->
  <main class="px-6 md:px-16 py-12 space-y-12">
    
    <!-- Category Block -->
    <section class="space-y-6">
      <div class="flex items-center justify-between border-b border-gray-800 pb-3">
        <h3 class="text-xl md:text-2xl font-bold tracking-wide">Popular Releases</h3>
        <a href="#" class="text-xs font-semibold uppercase text-red-500 hover:underline tracking-wider">View All</a>
      </div>
      
      <!-- Responsive Responsive Grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
        
        <!-- Movie Card Template (Repeat this block dynamically) -->
        <div class="group relative bg-gray-900 rounded-xl overflow-hidden cursor-pointer border border-gray-800 hover:border-gray-700 transition duration-300 transform hover:-translate-y-1 shadow-lg">
          <div class="aspect-[2/3] w-full bg-gray-800 overflow-hidden relative">
            <!-- Sample Poster Image -->
            <img src="https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?q=80&w=1000" alt="Movie Poster" class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
            <span class="absolute top-2 right-2 bg-gray-950/80 backdrop-blur-md text-yellow-500 text-xs font-bold px-2 py-0.5 rounded border border-gray-800">HD</span>
          </div>
          <div class="p-4 space-y-1">
            <h4 class="font-bold text-sm truncate group-hover:text-red-500 transition">The Grand Premiere</h4>
            <div class="flex items-center justify-between text-xs text-gray-400">
              <span>2026</span>
              <span class="text-yellow-500 font-medium">★ 8.4</span>
            </div>
          </div>
        </div>
        <!-- End Movie Card Template -->

      </div>
    </section>

  </main>

  <!-- Footer -->
  <footer class="border-t border-gray-900 bg-gray-950 px-6 py-8 text-center text-xs text-gray-500">
    <p>&copy; 2026 MovieClub. Built for cinema enthusiasts. Powered by public API streaming catalogs.</p>
  </footer>

</body>
</html>
